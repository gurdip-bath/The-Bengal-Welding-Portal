GEMINI_API_KEY=PLACEHOLDER_API_KEY
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# For scripts/cleanup-test-customer.mjs only (Supabase Dashboard → Settings → API → service_role):
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Edge Function env (set in Supabase dashboard / CLI, not in Vite)
SITE_URL=http://localhost:3000
GOCARDLESS_ENV=sandbox
GOCARDLESS_ACCESS_TOKEN=YOUR_GOCARDLESS_ACCESS_TOKEN
GOCARDLESS_WEBHOOK_SECRET=YOUR_GOCARDLESS_WEBHOOK_SECRET

# Service request initial fee (pence, default 15000 = £150)
INITIAL_SERVICE_FEE_PENCE=15000
